class Solution {
public:
    int countTrees(vector <int> &dp, int n) {
        if (n < 1) return 1; 
        if (dp[n] != -1) {
            return dp[n]; 
        }
        int temp = 0;  
        for (int i = 1; i <= n; i++) {
            temp += countTrees(dp, i - 1) * countTrees(dp, n - i); 
        }
        dp[n] = temp; 
        return dp[n]; 
    }
    int numTrees(int n) {
        if (n <= 2) return n; 
        vector <int> dp (n + 1, -1); 
        dp[1] = 1; 
        dp[2] = 2; 
        return countTrees(dp, n); 
    }
};
